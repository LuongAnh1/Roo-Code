    "# Lưu ý: Đảm bảo FaMIBaseScene đã được định nghĩa trước đó hoặc đổi thành Scene\n",
    "class mainScene(FaMIBaseScene):\n",
    "    def construct(self):\n",
    "        # PHẦN 1: PHÂN PHỐI CHUẨN VÀ LOGIC VÔ LÝ\n",
    "        title = self.create_title(\"ƯỚC LƯỢNG ĐỘ BỀN LINH KIỆN PISTON TRONG ĐỘNG CƠ Ô TÔ\")\n",
    "        self.play(Write(title))\n",
    "\n",
    "        text_title = Tex(r\"Phân phối chuẩn\", font_size=42)\n",
    "        axes = Axes(\n",
    "            x_range=[-4, 4, 1],\n",
    "            y_range=[0, 0.5, 0.1],\n",
    "            x_length=8,\n",
    "            y_length=4,\n",
    "            axis_config={\"include_tip\": False}\n",
    "        )\n",
    "        self.play(Create(axes))\n",
    "\n",
    "        def gaussian(x, mu=0, sigma=1):\n",
    "            return (1 / (sigma * np.sqrt(2 * np.pi))) * np.exp(-0.5 * ((x - mu) / sigma) ** 2)\n",
    "\n",
    "        graph = axes.plot(lambda x: gaussian(x), color=BLUE).set_fill(opacity=0)\n",
    "        negative_area = axes.get_area(\n",
    "            graph, x_range=[-4, 0], color=RED, opacity=0.8 \n",
    "        ).set_stroke(RED, width=2)\n",
    "\n",
    "        with self.voiceover(text=\"Làm sao để dự đoán giá một căn nhà khi bạn chỉ biết diện tích của nó?\") as tracker:\n",
    "            self.update_subtitle(\"Làm sao để dự đoán giá một căn nhà khi bạn chỉ biết diện tích của nó?\")\n",
    "            self.play(Create(graph), run_time=tracker.duration * 0.4)\n",
    "            self.play(Write(text_title.next_to(axes, UP)), run_time=tracker.duration * 0.6)\n",
    "\n",
    "        self.play(DrawBorderThenFill(negative_area), run_time=1.5)\n",
    "\n",
    "        math_logic = MathTex(\n",
    "            \"x < 0\", \"\\\\Rightarrow\", \"\\\\text{Tuổi thọ} < 0\", \"\\\\text{ (Vô lý!)}\",\n",
    "            font_size=36\n",
    "        ).set_color(YELLOW)\n",
    "        math_logic.next_to(negative_area, DOWN, buff=0.5)\n",
    "\n",
    "        self.play(Write(math_logic[0]))\n",
    "        self.wait(0.5)\n",
    "        self.play(Write(math_logic[1]), Write(math_logic[2]))\n",
    "        self.wait(0.5)\n",
    "        self.play(Indicate(math_logic[3], color=RED))\n",
    "        self.wait(1)\n",
    "\n",
    "        everything_wrong = VGroup(graph, negative_area, math_logic, axes, text_title)\n",
    "        cross = Cross(everything_wrong, stroke_width=15).set_color(WHITE)\n",
    "        \n",
    "        self.play(Create(cross))\n",
    "        self.wait(1)\n",
    "\n",
    "        # Dọn dẹp màn hình để sang phần Giải pháp\n",
    "        self.play(FadeOut(everything_wrong), FadeOut(cross))\n",
    "\n",
    "        # PHẦN 2: GIẢI PHÁP - Ý TƯỞNG LÓE LÊN\n",
    "       # 1. Vẽ Người Que to hơn nữa (Scale lên để lấp đầy khung dọc)\n",
    "        head = Circle(radius=0.55).set_stroke(WHITE, 5) # Tăng độ dày nét vẽ cho rõ\n",
    "        body = Line(head.get_bottom(), head.get_bottom() + 2.2 * DOWN).set_stroke(WHITE, 5)\n",
    "        \n",
    "        left_arm = Line(body.get_top(), body.get_top() + 1.4 * (DOWN + 0.3 * LEFT)).set_stroke(WHITE, 5)\n",
    "        right_arm = Line(body.get_top(), body.get_top() + 1.4 * (DOWN + 0.3 * RIGHT)).set_stroke(WHITE, 5)\n",
    "        \n",
    "        left_leg = Line(body.get_bottom(), body.get_bottom() + 1.4 * (DL * 0.7)).set_stroke(WHITE, 5)\n",
    "        right_leg = Line(body.get_bottom(), body.get_bottom() + 1.4 * (DR * 0.7)).set_stroke(WHITE, 5)\n",
    "        \n",
    "        student = VGroup(head, body, left_arm, right_arm, left_leg, right_leg)\n",
    "        student.center().shift(DOWN * 0.8)\n",
    "\n",
    "        # 2. Tạo 3 dấu hỏi màu đỏ (To hơn cho dễ nhìn)\n",
    "        q1 = Tex(\"?\", font_size=80, color=RED).next_to(head, UP, buff=0.5).shift(LEFT * 1.0)\n",
    "        q2 = Tex(\"?\", font_size=100, color=RED).next_to(head, UP, buff=0.7)\n",
    "        q3 = Tex(\"?\", font_size=80, color=RED).next_to(head, UP, buff=0.5).shift(RIGHT * 1.0)\n",
    "        questions = VGroup(q1, q2, q3)\n",
    "\n",
    "        # 3. Vẽ bóng đèn (Xử lý lớp vẽ để tia sáng không bị đè)\n",
    "        bulb_glass = Circle(radius=0.45, color=YELLOW, fill_opacity=0).set_stroke(YELLOW, 4)\n",
    "        bulb_base = Rectangle(height=0.25, width=0.35).next_to(bulb_glass, DOWN, buff=0.05).set_stroke(GRAY, 3)\n",
    "        \n",
    "        # Tạo các tia sáng xung quanh (Sparks)\n",
    "        glow_lines = VGroup(*[\n",
    "            Line(bulb_glass.get_center() + 0.6 * d, bulb_glass.get_center() + 1.0 * d).set_stroke(YELLOW, 4)\n",
    "            for d in [UP, UL, UR, LEFT, RIGHT]\n",
    "        ])\n",
    "\n",
    "        # Nhóm bóng đèn lại để quản lý vị trí\n",
    "        lightbulb = VGroup(bulb_glass, bulb_base).move_to(q2.get_center())\n",
    "\n",
    "        # 1. Hiện người que\n",
    "        self.play(FadeIn(student, shift=UP))\n",
    "        self.wait(0.5)\n",
    "\n",
    "        # 2. Hiện 3 dấu hỏi\n",
    "        with self.voiceover(text=\"Vấn đề ở đây là gì?\") as tracker:\n",
    "            self.update_subtitle(\"Vấn đề ở đây là gì?\")\n",
    "            self.play(LaggedStart(*[Write(q) for q in questions], lag_ratio=0.3))\n",
    "        self.wait(0.8)\n",
    "\n",
    "        # 3. Lóe sáng ý tưởng\n",
    "        spark_center = bulb_glass.get_top() + UP * 0.3\n",
    "        \n",
    "        glow_lines = VGroup(*[\n",
    "            Line(\n",
    "                spark_center + 0.1 * d, # Điểm bắt đầu (gần tâm tỏa sáng)\n",
    "                spark_center + 0.5 * d  # Điểm kết thúc (độ dài tia)\n",
    "            ).set_stroke(YELLOW, 4)\n",
    "            for d in [UP, UL, UR, LEFT, RIGHT]\n",
    "        ])\n",
    "\n",
    "        with self.voiceover(text=\"Và rồi, một giải pháp đã nảy ra...\") as tracker:\n",
    "            self.update_subtitle(\"Và rồi, một giải pháp đã nảy ra...\")\n",
    "            \n",
    "            # Biến dấu hỏi thành bóng đèn\n",
    "            self.play(\n",
    "                FadeOut(questions, scale=0.5),\n",
    "                FadeIn(bulb_base),\n",
    "                bulb_glass.animate.set_fill(YELLOW, opacity=0.8),\n",
    "                run_time=0.6\n",
    "            )\n",
    "            \n",
    "            # Hiệu ứng lóe sáng các tia spark ĐÃ ĐƯỢC DỊCH LÊN TRÊN\n",
    "            self.play(\n",
    "                Create(glow_lines),\n",
    "                Indicate(bulb_glass, scale_factor=1.15),\n",
    "                run_time=0.5\n",
    "            )\n",
    "        \n",
    "        everything_from_prev_scene = VGroup(student, lightbulb, glow_lines) \n",
    "\n",
    "        # 1. Dọn dẹp dứt khoát mọi thứ cũ để lấy chỗ cho đồ thị\n",
    "        self.play(FadeOut(everything_from_prev_scene), run_time=1)\n",
    "        self.wait(0.5)\n",
    "\n",
    "        # 1. Khởi tạo hệ trục (Không dùng to_edge ở đây)\n",
    "        axes_log = Axes(\n",
    "            x_range=[0, 5, 1],\n",
    "            y_range=[0, 1, 0.2],\n",
    "            x_length=8, # Tăng nhẹ chiều dài để cân đối\n",
    "            y_length=4.5,\n",
    "            axis_config={\"include_tip\": True, \"color\": WHITE}\n",
    "        )\n",
    "\n",
    "        # 2. Định nghĩa hàm và vẽ đồ thị\n",
    "        def log_normal_func(x, mu=0, sigma=0.5):\n",
    "            if x <= 0: return 0\n",
    "            return (1 / (x * sigma * np.sqrt(2 * np.pi))) * np.exp(-0.5 * ((np.log(x) - mu) / sigma) ** 2)\n",
    "\n",
    "        graph_log = axes_log.plot(\n",
    "            lambda x: log_normal_func(x), \n",
    "            x_range=[0.01, 5], \n",
    "            color=GREEN,\n",
    "            stroke_width=6\n",
    "        )\n",
    "        \n",
    "        graph_fill = axes_log.get_area(graph_log, x_range=[0.01, 5], color=GREEN, opacity=0.3)\n",
    "        log_normal_title = Tex(\"Phân phối Log-Chuẩn\", color=GREEN, font_size=48).next_to(axes_log, UP, buff=0.5)\n",
    "\n",
    "        # 3. Các thành phần phụ trợ\n",
    "        check_mark = Tex(r\"$\\checkmark$\", color=GREEN, font_size=160).move_to(axes_log.c2p(1.2, 0.6))\n",
    "        \n",
    "        tail_area = axes_log.get_area(graph_log, x_range=[2.2, 5], color=ORANGE, opacity=0.8)\n",
    "        \n",
    "        piston_label = Tex(\"Piston siêu bền\", color=ORANGE, font_size=40)\n",
    "        # Căn piston_label dựa trên tọa độ của trục để không bị lệch ngoài frame\n",
    "        piston_label.move_to(axes_log.c2p(3.8, 0.4)) \n",
    "\n",
    "        # --- BƯỚC QUAN TRỌNG: GOM NHÓM VÀ CĂN GIỮA ---\n",
    "        log_normal_group = VGroup(\n",
    "            axes_log, graph_log, graph_fill, \n",
